    {
      "id": "l1-body",
      "type": "text",
      "x": 104,
      "y": 196,
      "width": 700,
      "height": 96,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
