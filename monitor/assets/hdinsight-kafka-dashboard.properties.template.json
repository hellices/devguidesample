              {
                "name": "PartId",
                "value": "a5627661-a98e-4ef3-9c3b-b8c38521dd31",
                "isOptional": true
              },
              {
                "name": "Version",
                "value": "2.0",
                "isOptional": true
              },
              {
                "name": "TimeRange",
                "value": "P1D",
                "isOptional": true
              },
              {
                "name": "DashboardId",
                "isOptional": true
              },
              {
                "name": "DraftRequestParameters",
                "value": {
                  "scope": "hierarchy"
                },
                "isOptional": true
              },
              {
                "name": "Query",
                "value": "let LatestHeap =\n    HDInsightKafkaMetrics\n    | where TimeGenerated > ago(24h)\n    | where MetricNamespace == 'JVMMetrics'\n    | where MetricName in ('jvm_memoryheapused', 'jvm_memoryheapmax')\n    | extend Broker = case(\n        isnotempty(tostring(column_ifexists('Computer', ''))), tostring(column_ifexists('Computer', '')),\n        isnotempty(tostring(column_ifexists('HostName', ''))), tostring(column_ifexists('HostName', '')),\n        isnotempty(tostring(column_ifexists('Host', ''))), tostring(column_ifexists('Host', '')),\n        isnotempty(tostring(column_ifexists('InstanceName', ''))), tostring(column_ifexists('InstanceName', '')),\n        'cluster')\n    | summarize arg_max(TimeGenerated, MetricValue) by Broker, MetricName\n    | summarize HeapUsedMB = round(maxif(todouble(MetricValue), MetricName == 'jvm_memoryheapused') / 1048576.0, 2), HeapMaxMB = round(maxif(todouble(MetricValue), MetricName == 'jvm_memoryheapmax') / 1048576.0, 2) by Broker;\nlet LatestReplication =\n    HDInsightKafkaMetrics\n    | where TimeGenerated > ago(24h)\n    | where MetricName == 'UnderReplicatedPartitions'\n    | extend Broker = case(\n        isnotempty(tostring(column_ifexists('Computer', ''))), tostring(column_ifexists('Computer', '')),\n        isnotempty(tostring(column_ifexists('HostName', ''))), tostring(column_ifexists('HostName', '')),\n        isnotempty(tostring(column_ifexists('Host', ''))), tostring(column_ifexists('Host', '')),\n        isnotempty(tostring(column_ifexists('InstanceName', ''))), tostring(column_ifexists('InstanceName', '')),\n        'cluster')\n    | summarize arg_max(TimeGenerated, MetricValue) by Broker\n    | project Broker, UnderReplicatedPartitions = todouble(MetricValue);\nLatestHeap\n| join kind=fullouter LatestReplication on Broker\n| project Broker = coalesce(Broker, Broker1), HeapUsedMB, HeapMaxMB, UnderReplicatedPartitions = coalesce(UnderReplicatedPartitions, 0.0)\n| order by Broker asc\n",
                "isOptional": true
              },
